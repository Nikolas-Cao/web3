# 复制本文件为 .env 并填入实际值。.env 已在 .gitignore 中，勿提交。

# 部署与脚本用私钥（deploy、whitelist-open、reveal 等脚本均使用）
# 建议：将该私钥对应地址加入 config/whitelist.json，便于用本机 MetaMask 做白名单铸造验证
DEPLOYER_PRIVATE_KEY=

# 可选：测试网 RPC 与私钥（hardhat.config 中 NETWORK_TESTNET_URL 存在时启用 testnet）
# NETWORK_TESTNET_URL=
# NETWORK_TESTNET_PRIVATE_KEY=

# 可选：主网 RPC 与私钥
# NETWORK_MAINNET_URL=
# NETWORK_MAINNET_PRIVATE_KEY=

# 可选：区块浏览器 API Key（验证合约等）
# BLOCK_EXPLORER_API_KEY=

# 可选：Reveal 脚本 8_reveal.ts 使用的元数据 base URI，勿用占位值
# COLLECTION_URI_PREFIX=ipfs://__CID__/

# 可选：gas 报告
# REPORT_GAS=
# GAS_REPORTER_COIN_MARKET_CAP_API_KEY=

# 可选：扩展测试（大量 mint 等）
# EXTENDED_TESTS=
